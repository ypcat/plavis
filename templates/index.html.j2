<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>PLA Activity around Taiwan — plavis</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
<style>
  :root { color-scheme: light dark; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
                 Arial, "Noto Sans", "PingFang TC", "Microsoft JhengHei", sans-serif;
    margin: 0; padding: 1.25rem 1.5rem 3rem; max-width: 1280px; margin-inline: auto;
    background: #0f1115; color: #e6e8ec;
  }
  h1 { font-size: 1.4rem; margin: 0 0 .25rem; }
  p.sub { color: #8a93a6; margin: 0 0 1.25rem; font-size: .92rem; }
  .card { background: #171a21; border: 1px solid #242935; border-radius: 10px;
          padding: .75rem .75rem 1rem; margin-bottom: 1rem; }
  .card h2 { font-size: 1.05rem; margin: .15rem .25rem .6rem; }
  footer { margin-top: 1.5rem; color: #6c7386; font-size: .82rem; }
  a { color: #6ea8ff; }
  @media (prefers-color-scheme: light) {
    body { background: #f8f9fb; color: #1a1d24; }
    .card { background: #fff; border-color: #e2e6ef; }
    p.sub { color: #556; }
    footer { color: #667; }
  }
</style>
</head>
<body>
<h1>PLA activity around Taiwan</h1>
<p class="sub">
  Daily counts from the Taiwan MND bulletin.
  {{ n_rows }} days of data ·
  latest {{ latest_date }} ·
  generated {{ generated_at }} UTC.
</p>

<div class="card"><h2>Daily totals</h2><div id="totals" style="height:460px"></div></div>
<div class="card"><h2>ADIZ quadrant breakdown</h2><div id="adiz" style="height:380px"></div></div>

<footer>
  Source:
  <a href="https://www.mnd.gov.tw/news/plaactlist/1" target="_blank" rel="noopener">
    mnd.gov.tw · PLA Activities
  </a>.
  Totals are parsed directly from the bulletin text.
  Code: <a href="https://github.com/ypcat/plavis" target="_blank" rel="noopener">ypcat/plavis</a>.
</footer>

<script id="csv-data" type="text/plain">{{ csv_text }}</script>
<script>
(function () {
  const csv = document.getElementById('csv-data').textContent;

  function parseCSV(text) {
    const lines = text.replace(/\r/g, '').split('\n').filter(l => l.length);
    const header = lines.shift().split(',');
    return lines.map(line => {
      const cols = line.split(',');
      const row = {};
      header.forEach((h, i) => { row[h] = cols[i] ?? ''; });
      return row;
    });
  }
  function asNum(v) { if (v === '' || v == null) return null; const n = +v; return Number.isFinite(n) ? n : null; }

  // Trailing simple moving average that ignores gaps; null where no data in the window.
  function movingAverage(ys, window) {
    return ys.map((_, i) => {
      let sum = 0, n = 0;
      for (let j = Math.max(0, i - window + 1); j <= i; j++) {
        if (ys[j] != null) { sum += ys[j]; n++; }
      }
      return n ? sum / n : null;
    });
  }
  const MA_WINDOW = 7;

  const rows = parseCSV(csv);
  const dates = rows.map(r => r.date);
  const headerCols = Object.keys(rows[0] || {});

  const totalSeries = [
    ['total_aircraft', 'All PLA aircraft'],
    ['median_crossings', 'Crossed median line'],
    ['plan_vessels', 'PLAN vessels'],
    ['official_ships', 'Official ships'],
  ];

  const totalsData = [];
  totalSeries
    .filter(([k]) => headerCols.includes(k))
    .forEach(([k, name]) => {
      const y = rows.map(r => asNum(r[k]));
      totalsData.push({
        x: dates, y,
        type: 'scatter', mode: 'lines+markers',
        name, legendgroup: k, connectgaps: false,
        hovertemplate: '%{x}<br>' + name + ': %{y}<extra></extra>',
      });
      // Smoothed overlay shares the legend entry so one click toggles both.
      totalsData.push({
        x: dates, y: movingAverage(y, MA_WINDOW),
        type: 'scatter', mode: 'lines',
        name: name + ' (' + MA_WINDOW + 'd avg)',
        legendgroup: k, showlegend: false, connectgaps: false,
        line: { dash: 'dot', width: 2 },
        hovertemplate: '%{x}<br>' + name + ' (' + MA_WINDOW + 'd avg): %{y:.1f}<extra></extra>',
      });
    });

  const darkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;

  const rangeSelector = {
    bgcolor:     darkMode ? '#242935' : '#f0f2f7',
    activecolor: darkMode ? '#3a4560' : '#c8cfe0',
    bordercolor: darkMode ? '#3a4560' : '#c8cfe0',
    font: { color: darkMode ? '#e6e8ec' : '#1a1d24' },
    buttons: [
      { step: 'day',   stepmode: 'backward', count: 7,  label: '7d' },
      { step: 'day',   stepmode: 'backward', count: 30, label: '30d' },
      { step: 'day',   stepmode: 'backward', count: 90, label: '90d' },
      { step: 'year',  stepmode: 'backward', count: 1,  label: '1y' },
      { step: 'all',   label: 'all' },
    ],
  };

  const layoutBase = {
    paper_bgcolor: 'rgba(0,0,0,0)',
    plot_bgcolor: 'rgba(0,0,0,0)',
    font: { color: getComputedStyle(document.body).color },
    margin: { l: 50, r: 20, t: 10, b: 70 },
    legend: { orientation: 'h', y: -0.25, itemclick: 'toggle', itemdoubleclick: 'toggleothers' },
    xaxis: { type: 'date', rangeselector: rangeSelector, rangeslider: { visible: true } },
    hovermode: 'x unified',
    hoverlabel: {
      bgcolor:     darkMode ? '#1e2535' : '#ffffff',
      bordercolor: darkMode ? '#3a4560' : '#c8cfe0',
      font: { color: darkMode ? '#e6e8ec' : '#1a1d24' },
      namelength: -1,
    },
  };

  // Helper: after x-axis zoom/pan, rescale y-axis to visible data range
  function attachAutoY(gd, isStacked) {
    let busy = false;
    gd.on('plotly_relayout', function (event) {
      if (busy) return;
      if (event['xaxis.autorange']) {
        busy = true;
        Plotly.relayout(gd, { 'yaxis.autorange': true })
          .then(function () { busy = false; })
          .catch(function () { busy = false; });
        return;
      }
      // Box zoom, range slider, and rangeselector buttons report bounds as
      // separate 'xaxis.range[0]'/'xaxis.range[1]' keys, not 'xaxis.range'.
      const rng = event['xaxis.range'] ||
        (event['xaxis.range[0]'] != null && event['xaxis.range[1]'] != null
          ? [event['xaxis.range[0]'], event['xaxis.range[1]']]
          : null);
      if (!rng || !rng[0] || !rng[1]) return;
      busy = true;
      const x0 = new Date(rng[0]).getTime();
      const x1 = new Date(rng[1]).getTime();
      let ymin = Infinity, ymax = -Infinity;
      const traces = gd.data;
      if (isStacked) {
        // For stacked charts: sum contributions per x index
        const xs = traces[0] && traces[0].x;
        if (xs) {
          for (let i = 0; i < xs.length; i++) {
            const t = new Date(xs[i]).getTime();
            if (t < x0 || t > x1) continue;
            let sum = 0;
            let any = false;
            for (let di = 0; di < traces.length; di++) {
              const v = traces[di].y[i];
              if (v != null && Number.isFinite(v)) { sum += v; any = true; }
            }
            if (any) { if (sum < ymin) ymin = sum; if (sum > ymax) ymax = sum; }
          }
        }
      } else {
        for (let di = 0; di < traces.length; di++) {
          const t = traces[di];
          const xs = t.x, ys = t.y;
          if (!xs) continue;
          for (let i = 0; i < xs.length; i++) {
            const ti = new Date(xs[i]).getTime();
            if (ti < x0 || ti > x1) continue;
            const y = ys[i];
            if (y != null && Number.isFinite(y)) {
              if (y < ymin) ymin = y;
              if (y > ymax) ymax = y;
            }
          }
        }
      }
      if (ymin === Infinity) { busy = false; return; }
      const pad = (ymax - ymin) * 0.08 || 0.5;
      Plotly.relayout(gd, { 'yaxis.range': [ymin - pad, ymax + pad] })
        .then(function () { busy = false; })
        .catch(function () { busy = false; });
    });
  }

  var totalsDiv = document.getElementById('totals');
  Plotly.newPlot(totalsDiv, totalsData, { ...layoutBase }, { responsive: true, displaylogo: false });
  attachAutoY(totalsDiv, false);

  const adizSeries = [
    ['n_adiz',  'North ADIZ'],
    ['sw_adiz', 'Southwest ADIZ'],
    ['e_adiz',  'East ADIZ'],
    ['se_adiz', 'Southeast ADIZ'],
  ];
  const adizData = adizSeries
    .filter(([k]) => headerCols.includes(k))
    .map(([k, name]) => ({
      x: dates,
      y: rows.map(r => asNum(r[k])),
      stackgroup: 'one',
      type: 'scatter', mode: 'lines',
      name,
      hovertemplate: '%{x}<br>' + name + ': %{y}<extra></extra>',
    }));
  const hasAdiz = adizData.some(s => s.y.some(v => v != null));
  if (!hasAdiz) {
    document.getElementById('adiz').innerHTML =
      '<p style="color:#8a93a6;padding:.75rem">ADIZ per-quadrant breakdowns not available for the current dataset (MND stopped reporting per-quadrant counts in late January 2024).</p>';
  } else {
    var adizDiv = document.getElementById('adiz');
    Plotly.newPlot(adizDiv, adizData, { ...layoutBase }, { responsive: true, displaylogo: false });
    attachAutoY(adizDiv, true);
  }
})();
</script>
</body>
</html>
